# App Store Server Notifications Webhook

# Telegram Bot (shared across all apps)
# Create a bot via @BotFather and get the token
TELEGRAM_BOT_TOKEN=
# Chat ID (use @userinfobot to find your chat ID, or a channel ID like -1001234567890)
TELEGRAM_CHAT_ID=

# Apps — format: APP_<SLUG>=<bundleId>:<appAppleId>
# The slug becomes the URL path: /api/apple/<slug>
APP_MYAPP=com.yourcompany.myapp:1234567890

